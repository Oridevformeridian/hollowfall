datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

model PlayerAccount {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Display name is only for in-game rendering, not for login.
  displayName     String?          
  
  identities      LinkedIdentity[]
}

model LinkedIdentity {
  id              String        @id @default(uuid())
  provider        String        // e.g., "google", "steam"
  providerId      String        // The opaque ID from the SSO provider
  playerAccountId String
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([provider, providerId])
}
